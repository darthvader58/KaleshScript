// KaleshScript Example - Delhi ki coding language!

// Variable declaration
chutiye ye x hai 42
chutiye ye naam hai "Bhai"
chutiye ye status hai sahi

bhauk "Hello from KaleshScript!"
bhauk naam
bhauk x

// If-else
bsdk agar x > 40 kar:
    bhauk "X bada hai bc"
warna:
    bhauk "X chota hai"

// Loop
chutiye ye count hai 0
jab tak maa count < 5 na maane:
    bhauk count
    count = count + 1

// Arrays
chutiye ye numbers hai [1, 2, 3, 4, 5]
bhauk numbers[0]
bhauk numbers[2]

// Hash/Dictionary
chutiye ye person hai {"name": "Rahul", "age": 25}
bhauk person["name"]

// Switch case
chutiye ye feeling hai "happy"
mood feeling {
    dekh "happy":
        bhauk "Party karte hain!"
    dekh "sad":
        bhauk "Daaru lao yaar"
    default:
        bhauk "Therapy le bhai"
}

// Try-catch
try kar:
    bhauk "Trying something risky..."
, pakad mc:
    bhauk "Lafda ho gaya!"

bhauk "Program khatam!"

nikal lawde
