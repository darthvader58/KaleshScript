// Boolean values demo

chutiye ye truth hai sahi
chutiye ye lie hai bekaar

bhauk truth
bhauk lie

bsdk agar truth kar:
    bhauk "Sahi hai bhai!"

bsdk agar lie kar:
    bhauk "Ye nahi chalega"
warna:
    bhauk "Bekaar hai ye"

// Comparisons
chutiye ye a hai 10
chutiye ye b hai 20

bsdk agar a < b kar:
    bhauk "A chota hai B se"

bsdk agar a == 10 kar:
    bhauk "A is exactly 10"


nikal lawde
